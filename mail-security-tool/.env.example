# Configuration des clés API
# INSTRUCTIONS: Copie ce fichier en .env et remplis tes propres clés API
# cp .env.example .env

# VirusTotal API Key (https://virustotal.com)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLScan.io API Key (https://urlscan.io)
URLSCAN_API_KEY=your_urlscan_api_key_here

# AbuseIPDB API Key (https://abuseipdb.com)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# SCAMDOC / ScamPredictor API (RapidAPI - https://rapidapi.com/scampredictor/api/scampredictor)
SCAMDOC_API_KEY=your_scamdoc_api_key_here
SCAMDOC_BASE_URL=https://scampredictor.p.rapidapi.com
SCAMDOC_URL_PATH=/Domain_trustscore/{domain_name}
SCAMDOC_EMAIL_PATH=/Email_trustscore/{email}
SCAMDOC_RAPIDAPI_HOST=scampredictor.p.rapidapi.com

# Hybrid Analysis Sandbox API (FREE - https://hybrid-analysis.com)
HYBRID_ANALYSIS_ENABLED=true
HYBRID_ANALYSIS_API_KEY=your_hybrid_analysis_api_key_here
HYBRID_ANALYSIS_BASE_URL=https://www.hybrid-analysis.com/api/v2
HYBRID_ANALYSIS_USER_AGENT=secanalyze-tool-1.0
HYBRID_ANALYSIS_TIMEOUT=60
HYBRID_ANALYSIS_MAX_FILESIZE_MB=30

# ============================================
# MXToolbox - Infrastructure & DNS Checks
# ============================================
MXTOOLBOX_ENABLED=true
MXTOOLBOX_API_KEY=
MXTOOLBOX_BASE_URL=https://mxtoolbox.com/api/v1
MXTOOLBOX_TIMEOUT=10


# Database
DB_PATH=data/results.db

# Configuration Flask
FLASK_ENV=development
FLASK_DEBUG=1
